<?xml version="1.0" encoding="utf-8"?>
<robot name="boxbot">

  <link name="base_link">
    <visual>
      <geometry><box size="0.4 0.2 0.1"/></geometry>
      <material name="blue"><color rgba="0 0 0.8 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.4 0.2 0.1"/></geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.0041" ixy="0" ixz="0" iyy="0.0141" iyz="0" izz="0.0166"/>
    </inertial>
  </link>

  <link name="fl_leg">
    <visual>
      <origin xyz="0 0 -0.1"/>
      <geometry><box size="0.05 0.05 0.2"/></geometry>
      <material name="grey"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.1"/>
      <geometry><box size="0.05 0.05 0.2"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.1"/>
      <mass value="0.2"/>
      <inertia ixx="0.0007" ixy="0" ixz="0" iyy="0.0007" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="fl_joint" type="revolute">
    <parent link="base_link"/>
    <child link="fl_leg"/>
    <origin xyz="0.15 0.1 -0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.5" upper="0.5" effort="10" velocity="1.0"/>
  </joint>

  <link name="fr_leg">
    <visual>
      <origin xyz="0 0 -0.1"/>
      <geometry><box size="0.05 0.05 0.2"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 -0.1"/>
      <geometry><box size="0.05 0.05 0.2"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.1"/>
      <mass value="0.2"/>
      <inertia ixx="0.0007" ixy="0" ixz="0" iyy="0.0007" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="fr_joint" type="revolute">
    <parent link="base_link"/>
    <child link="fr_leg"/>
    <origin xyz="0.15 -0.1 -0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.5" upper="0.5" effort="10" velocity="1.0"/>
  </joint>

  <link name="rl_leg">
    <visual>
      <origin xyz="0 0 -0.1"/>
      <geometry><box size="0.05 0.05 0.2"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 -0.1"/>
      <geometry><box size="0.05 0.05 0.2"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.1"/>
      <mass value="0.2"/>
      <inertia ixx="0.0007" ixy="0" ixz="0" iyy="0.0007" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="rl_joint" type="revolute">
    <parent link="base_link"/>
    <child link="rl_leg"/>
    <origin xyz="-0.15 0.1 -0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.5" upper="0.5" effort="10" velocity="1.0"/>
  </joint>

  <link name="rr_leg">
    <visual>
      <origin xyz="0 0 -0.1"/>
      <geometry><box size="0.05 0.05 0.2"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 -0.1"/>
      <geometry><box size="0.05 0.05 0.2"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.1"/>
      <mass value="0.2"/>
      <inertia ixx="0.0007" ixy="0" ixz="0" iyy="0.0007" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="rr_joint" type="revolute">
    <parent link="base_link"/>
    <child link="rr_leg"/>
    <origin xyz="-0.15 -0.1 -0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.5" upper="0.5" effort="10" velocity="1.0"/>
  </joint>

</robot>